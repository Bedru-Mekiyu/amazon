# Backend Configuration
# Copy to .env and fill in your values.

# Server
PORT=3000
NODE_ENV=development

# Frontend origin (used for CORS in production)
# FRONTEND_URL=https://your-frontend-domain.com

# Database
# Default: SQLite (no config needed — auto-creates backend/database.sqlite)
# For MySQL/PostgreSQL, set DB_TYPE and RDS_* variables below:

# DB_TYPE=mysql        # or postgres
# RDS_DB_NAME=amazon
# RDS_USERNAME=your_user
# RDS_PASSWORD=your_password
# RDS_HOSTNAME=your-host.amazonaws.com
# RDS_PORT=3306        # 5432 for postgres
