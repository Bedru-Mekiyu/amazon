# Frontend Configuration
# Copy to .env and fill in your values.

# Backend API URL (for Vercel/Render deployment)
# When empty, the frontend assumes API is at the same origin (Vite proxy or Docker).
# Set to your Render backend URL when deploying frontend to Vercel:
# VITE_API_URL=https://amazon-api.onrender.com
# VITE_API_URL=
