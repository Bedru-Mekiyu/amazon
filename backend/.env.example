# Backend Configuration
# Copy to .env and fill in your values.

# Server
PORT=3000
NODE_ENV=development

# Frontend origin (used for CORS in production)
# Set to your Vercel frontend URL when deploying backend to Render.
# Can be comma-separated for multiple preview URLs:
# FRONTEND_URL=https://amazon.vercel.app,https://amazon-git-feat-xxx.vercel.app
# When unset, the backend serves the frontend from dist/ (Docker/single-server mode).
# FRONTEND_URL=https://amazon.vercel.app

# Database (SQLite used by default — no config needed)
# DB_TYPE=sqlite

# For MySQL or PostgreSQL:
# DB_TYPE=mysql
# RDS_DB_NAME=amazon
# RDS_USERNAME=amazon
# RDS_PASSWORD=your_password
# RDS_HOSTNAME=your-db-host
# RDS_PORT=3306
